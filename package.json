{
  "name": "dezlymacauley-dot-com",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 6969 --open",
    "build": "bun --bun vite build",
    "preview": "vite preview --port 6969 --open",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check .",
    "clean": "rm -rf .svelte-kit .vercel node_modules",
    "setup": "mise trust && bun run clean && bun install"
  },
  "devDependencies": {
    "@sveltejs/adapter-vercel": "6.2.0",
    "@sveltejs/kit": "2.49.2",
    "@sveltejs/vite-plugin-svelte": "6.2.1",
    "@tailwindcss/vite": "4.1.18",
    "@types/bun": "1.3.5",
    "prettier": "3.7.4",
    "prettier-plugin-svelte": "3.4.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "svelte": "5.46.1",
    "svelte-check": "4.3.5",
    "tailwindcss": "4.1.18",
    "typescript": "5.9.3",
    "vite": "7.3.0"
  }
}
