{
	"name": "dezlymacauley-dot-com",
	"private": true,
	"version": "0.0.1",
	"type": "module",
  "scripts": {
      "dev": "vite dev --open --port 6969",
      "build": "vite build",
      "preview": "vite preview --open --port 6969",
